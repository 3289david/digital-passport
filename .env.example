# Database (PostgreSQL — Neon, Supabase, Vercel Postgres, or local)
DATABASE_URL="postgresql://user:password@host:5432/digitalpassport"

# Auth.js secret — generate with: openssl rand -base64 32
AUTH_SECRET="your-secret-here"

# GitHub OAuth App (https://github.com/settings/developers)
# Callback URL: https://your-domain.com/api/auth/callback/github
GITHUB_CLIENT_ID="your-github-client-id"
GITHUB_CLIENT_SECRET="your-github-client-secret"

# Google OAuth App (https://console.cloud.google.com → APIs & Services → Credentials)
# Callback URL: https://your-domain.com/api/auth/callback/google
GOOGLE_CLIENT_ID="your-google-client-id"
GOOGLE_CLIENT_SECRET="your-google-client-secret"

# App URL (used for OG images and absolute URLs)
NEXT_PUBLIC_APP_URL="https://p.krl.kr"
