// Digital Passport — Prisma Schema
// Database: PostgreSQL (Neon / Supabase / Vercel Postgres)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

// ─── Auth (NextAuth.js v5 required tables) ─────────────────────────────────

model User {
  id            String    @id @default(cuid())
  email         String?   @unique
  emailVerified DateTime?
  name          String?
  image         String?

  accounts Account[]
  sessions Session[]
  passport Passport?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Account {
  id                String  @id @default(cuid())
  userId            String
  type              String
  provider          String
  providerAccountId String
  refresh_token     String? @db.Text
  access_token      String? @db.Text
  expires_at        Int?
  token_type        String?
  scope             String?
  id_token          String? @db.Text
  session_state     String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ─── Passport ───────────────────────────────────────────────────────────────

model Passport {
  id               String  @id @default(cuid())
  userId           String  @unique
  username         String  @unique
  displayName      String?
  title            String?
  bio              String? @db.Text
  location         String?
  website          String?
  twitterHandle    String?
  available        Boolean @default(false)
  availabilityNote String?
  passportNumber   String  @unique @default(cuid())
  avatarUrl        String? @db.Text

  // Computed scores (refreshed on sync)
  trustScore    Int @default(0)
  securityScore Int @default(0)

  // Sync state
  lastSyncedAt DateTime?
  syncStatus   String?   @default("pending") // pending | syncing | done | error

  user        User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  connections ConnectedAccount[]
  projects    Project[]
  packages    Package[]
  skills      Skill[]
  badges      Badge[]
  verifications Verification[]
  experiences  Experience[]
  securityChecks SecurityCheck[]
  contributionYears ContributionYear[]
  visasReceived DeveloperVisa[]   @relation("VisaRecipient")
  teamMemberships TeamMember[]
  site          PassportSite?
  apiKeys       ApiKey[]
  trustLogs     TrustScoreLog[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}

model ConnectedAccount {
  id           String  @id @default(cuid())
  passportId   String
  platform     String // github | gitlab | npm | docker | pypi | crates | huggingface | vercel | cloudflare | stackoverflow | x | discord
  handle       String
  url          String?
  accessToken  String? @db.Text
  verified     Boolean @default(false)
  public       Boolean @default(true)
  metadata     Json?   // platform-specific cached data

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([passportId, platform])
  @@index([passportId])
}

model Project {
  id             String  @id @default(cuid())
  passportId     String
  externalId     String? // e.g., GitHub repo ID
  platform       String  @default("github")
  name           String
  fullName       String? // e.g., "danu/rukkit"
  description    String? @db.Text
  url            String?
  stars          Int     @default(0)
  forks          Int     @default(0)
  watchers       Int     @default(0)
  openIssues     Int     @default(0)
  downloads      Int?
  language       String?
  languageColor  String?
  license        String?
  healthScore    Int     @default(0)
  contributors   Int     @default(0)
  startedAt      String?
  pushedAt       DateTime?
  isArchived     Boolean @default(false)
  isFork         Boolean @default(false)
  featured       Boolean @default(false)

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([passportId, platform, externalId])
  @@index([passportId])
}

model Package {
  id          String  @id @default(cuid())
  passportId  String
  name        String
  registry    String // npm | pypi | docker | crates | maven | gem
  version     String?
  downloads   Int     @default(0)
  description String? @db.Text
  url         String?

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@unique([passportId, registry, name])
  @@index([passportId])
}

model Skill {
  id         String  @id @default(cuid())
  passportId String
  name       String
  score      Int
  color      String?
  category   String? // language | framework | domain | tool

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([passportId, name])
  @@index([passportId])
}

model Badge {
  id         String    @id @default(cuid())
  passportId String
  type       String // oss_maintainer | security_expert | top_reviewer | rust_expert | ai_builder | 1000_commits | 100_releases | oss_sponsor | bug_hunter | docs_master
  label      String
  earned     Boolean   @default(false)
  earnedAt   DateTime?

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([passportId, type])
  @@index([passportId])
}

model Verification {
  id          String    @id @default(cuid())
  passportId  String
  type        String // email | github | google | domain | ssh_key | gpg_key | wallet | gov_id | company_email | school_email
  level       String // basic | advanced | elite
  verified    Boolean   @default(false)
  verifiedAt  DateTime?
  metadata    Json?

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([passportId, type])
  @@index([passportId])
}

model Experience {
  id          String  @id @default(cuid())
  passportId  String
  year        String
  title       String
  description String? @db.Text
  type        String // project | company | milestone | education
  order       Int     @default(0)
  url         String?

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([passportId])
}

model SecurityCheck {
  id         String  @id @default(cuid())
  passportId String
  label      String
  status     String // pass | warn | fail | unknown
  detail     String? @db.Text

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt

  @@unique([passportId, label])
}

model ContributionYear {
  id         String @id @default(cuid())
  passportId String
  year       Int
  weeks      Json   // Int[] — 52 values

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  @@unique([passportId, year])
  @@index([passportId])
}

model TrustScoreLog {
  id         String @id @default(cuid())
  passportId String
  score      Int
  breakdown  Json   // { commits, quality, community, packages, security, verification, longevity }

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([passportId])
}

// ─── API Keys ────────────────────────────────────────────────────────────────

model ApiKey {
  id         String    @id @default(cuid())
  passportId String
  name       String
  key        String    @unique
  lastUsedAt DateTime?
  expiresAt  DateTime?
  active     Boolean   @default(true)

  passport Passport @relation(fields: [passportId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([key])
  @@index([passportId])
}

// ─── Organizations + Developer Visa ─────────────────────────────────────────

model Organization {
  id          String  @id @default(cuid())
  name        String
  slug        String  @unique
  description String? @db.Text
  website     String?
  logoUrl     String?
  verified    Boolean @default(false)
  ownerId     String

  teamPassport TeamPassport?
  visasIssued  DeveloperVisa[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([slug])
}

model DeveloperVisa {
  id             String    @id @default(cuid())
  organizationId String
  passportId     String
  title          String    // e.g., "Cloudflare Certified Developer"
  description    String?   @db.Text
  issuedAt       DateTime  @default(now())
  expiresAt      DateTime?
  active         Boolean   @default(true)

  organization Organization @relation(fields: [organizationId], references: [id])
  passport     Passport     @relation("VisaRecipient", fields: [passportId], references: [id])

  @@index([passportId])
  @@index([organizationId])
}

// ─── Team Passport ───────────────────────────────────────────────────────────

model TeamPassport {
  id             String  @id @default(cuid())
  organizationId String  @unique
  name           String
  description    String? @db.Text
  trustScore     Int     @default(0)
  velocity       Int     @default(0) // commits/week
  healthScore    Int     @default(0)

  organization Organization @relation(fields: [organizationId], references: [id])
  members      TeamMember[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TeamMember {
  id             String @id @default(cuid())
  teamPassportId String
  passportId     String
  role           String @default("member") // owner | admin | member

  teamPassport TeamPassport @relation(fields: [teamPassportId], references: [id])
  passport     Passport     @relation(fields: [passportId], references: [id])

  joinedAt DateTime @default(now())

  @@unique([teamPassportId, passportId])
}

// ─── Personal Site ───────────────────────────────────────────────────────────

model PassportSite {
  id           String  @id @default(cuid())
  passportId   String  @unique
  theme        String  @default("minimal") // minimal | terminal | portfolio | card
  title        String?
  headline     String? @db.Text
  ctaText      String?
  ctaUrl       String?
  showProjects Boolean @default(true)
  showSkills   Boolean @default(true)
  showBadges   Boolean @default(true)
  showContact  Boolean @default(true)
  accentColor  String  @default("#4361ee")
  customCss    String? @db.Text
  customHtml   String? @db.Text
  customJs     String? @db.Text

  passport Passport @relation(fields: [passportId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
